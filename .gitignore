# ============================================================
# .gitignore
# Author: Lori Murray | github.com/Lamurrz
# Purpose: Prevent secrets, credentials, build artifacts, and
#          environment-specific files from being committed.
# ============================================================


# ── Secrets & Credentials ─────────────────────────────────────────────────
# These should NEVER appear in a public repo under any circumstances
.env
.env.*
.env.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets.yml
secrets.yaml
secrets.json
credentials.json
config/secrets*
*_credentials*
*_secret*
api_keys*
auth_tokens*
token.json
token.pickle


# ── Python Runtime ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Distribution / packaging
build/
dist/
eggs/
*.egg
*.egg-info/
.eggs/
wheels/
sdist/
var/
*.manifest
*.spec
MANIFEST

# Virtual environments — never commit these
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/
pipenv/
.pipenv/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt


# ── Jupyter Notebooks ──────────────────────────────────────────────────────
# Strip output cells before committing — they can contain sensitive data
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
# Uncomment the line below to block notebooks entirely if preferred:
# *.ipynb


# ── Testing & Coverage ─────────────────────────────────────────────────────
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/
*.cover
nosetests.xml
test-results/
pytestdebug.log


# ── Linting & Type Checking ────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/


# ── IDEs & Editors ─────────────────────────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json   # Safe to share recommended extensions

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
Session.vim

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyproject/
.spyderproject.cfg


# ── Operating System ───────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*


# ── Security Research Specific ─────────────────────────────────────────────
# Sample malware, payloads, or test artifacts — never commit real samples
samples/
malware/
payloads/
*.malware
*.sample

# PCAP / network captures — can contain sensitive traffic
*.pcap
*.pcapng
*.cap

# Scan output files that may contain sensitive target info
scan_results/
nmap_output/
*.nmap
*.gnmap
*.xml.bak

# Local analysis notes not intended for public view
notes/
scratch/
todo_private*
analyst_notes*

# CodeQL SARIF output (retained as Actions artifact instead)
codeql-results/
*.sarif


# ── Logs & Databases ───────────────────────────────────────────────────────
*.log
*.sql
*.sqlite
*.sqlite3
*.db
logs/
log/


# ── Miscellaneous ──────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.rej
.cache/
tmp/
temp/
